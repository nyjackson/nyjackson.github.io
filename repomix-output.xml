<file path="styles/Projects.css">
/* ============================================================
   styles/Projects.css
   Unified Layout System — Selected Projects
   ============================================================ */

/* Main Section Block Layout Container */
.projects {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: var(--space-8) var(--space-5); /* Symmetrical alignment wrapper */
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* Section Header Typography */
.projects .section-eyebrow {
  font-family: var(--font-display); /* Fraunces */
  font-size: 1.5rem; 
  font-weight: 300;
  font-style: italic;
  color: var(--color-text);
  border-bottom: 1px solid var(--color-border); 
  padding-bottom: var(--space-2);
  display: inline-block;
  min-width: 150px;
  align-self: flex-start;
  margin: 0;
}

/* Header Group: Formats the interactive space below title */
.projects-header-group {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-5);
  margin-bottom: var(--space-6);
}

/* Filtering Toolbar Layout */
.filter-bar {
  display: flex;
  justify-content: flex-start; 
  gap: var(--space-2);
  padding: 0;
  flex-wrap: wrap; /* Wraps cleanly on low resolution mobile devices */
}

/* Pill Styling for Filter Action Triggers */
.filter-pill {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--color-text-muted);
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  padding: 6px 14px;
  border-radius: var(--radius-xl);
  cursor: pointer;
  transition: all var(--transition-fast);
}

.filter-pill:hover, 
.filter-pill.active {
  color: var(--color-text);
  border-color: var(--color-border-strong);
}

.filter-pill.active {
  background: var(--color-bg-tertiary);
}

/* Responsive Project Matrix Grid Layout */
.project-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
  align-items: stretch;
}

/* Individual Project Card Block Wrapper */
.project-card {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  transition: all var(--transition-fast);
}

/* Highlights High-Stakes Systems (Enterprise/HIPAA work) */
.project-card.featured {
  border-left: 4px solid var(--accent);
  background: var(--color-bg-tertiary);
}

.project-card:hover {
  border-color: var(--color-border-strong);
  transform: translateY(-2px);
}

.card-header {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.project-title {
  font-family: var(--font-display); /* Fraunces */
  font-size: 1.35rem;
  font-weight: 500;
  line-height: 1.2;
  color: var(--color-text);
}

.project-year {
  font-size: 11px;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* Flexible Description — Pushes child footer components down evenly */
.project-description {
  font-family: var(--font-body); /* Outfit */
  font-size: 14px;
  line-height: 1.6;
  color: var(--color-text-muted);
  margin: var(--space-4) 0;
  flex-grow: 1; 
}

/* Quantitative Business Stats Grid Layout */
.project-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
  padding: var(--space-3) var(--space-4);
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}

[data-theme="dark"] .project-stats {
  background: rgba(0, 0, 0, 0.15); /* Adds visual depth in dark mode */
}

.stat-value {
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 14px;
  color: var(--color-text);
  display: block;
}

.stat-label {
  font-size: 11px;
  color: var(--color-text-muted);
}

/* Tooling / Language Chips Layout */
.tech-stack {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2); 
  margin-bottom: var(--space-5);
}

.tech-pill {
  font-size: 11px;
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  color: var(--color-text-muted);
}

/* Action Links Footer Layer */
.project-links {
  display: flex;
  align-items: center;
  gap: var(--space-4); 
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-4);
  margin-top: auto; /* Pins layout items perfectly to the container's baseline */
}

.project-link {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.project-link:hover {
  color: var(--color-text);
}

.internal-lock {
  font-size: 11px;
  font-style: italic;
  color: var(--color-text-faint);
}

/* ============================================================
   RESPONSIVE LAYOUT CONSTRAINTS
   ============================================================ */
@media (max-width: 768px) {
  .project-grid { 
    grid-template-columns: 1fr; /* Collapses dual column grid layout down to single on small viewports */
  }
  
  .projects { 
    padding: var(--space-6) var(--space-4); 
  }
}
</file>

<file path="styles/Skills.css">
/* ============================================================
   Skills Section Revamp
   ============================================================ */

.skills {
  padding: var(--space-8) var(--space-8);
  border-top: 1px solid var(--color-border);
}

.section-eyebrow {
  font-family: var(--font-display); /* Fraunces */
  font-size: 1.5rem; /* Larger than a label, smaller than the Hero name */
  font-weight: 300;
  font-style: italic;
  color: var(--color-text); /* Brighter than muted to show it's a section start */
  margin-bottom: var(--space-6);
  border-bottom: 1px solid var(--color-border); /* Subtle line to ground the section */
  padding-bottom: var(--space-2);
  display: inline-block;
  min-width: 150px;
}

.section-eyebrow::after {
  content: "";
  flex: 1;
  height: 1px;
  background: var(--color-border);
}

.skills-grid {
  display: grid;
  /* Allows cards to be responsive but keeps the 3-column intent */
grid-template-columns: repeat(3, 1fr);  /* REMOVE grid-auto-rows: 1fr; to let cards hug their content */
  gap: var(--space-4);
  align-items: stretch;
}

.skill-card {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5); /* Slightly more padding for breathability */
  transition: all var(--transition-fast);
  border-top: 3px solid var(--color-accent-mid); /* Adds a professional "tab" look */
  padding-top: var(--space-4);
}

.skill-card:hover {
  border-color: var(--color-accent-mid); /* Subtle color pop on hover */
  transform: translateY(-2px); /* Adds a tactile feel */
}

.skill-list {
  list-style: none;
  display: flex;
  flex-wrap: wrap; /* Key change: skills flow horizontally */
  gap: var(--space-2);
  margin-top: var(--space-3);
}

.skill-list li {
  font-size: 12px;
  font-family: var(--font-body); /* Outfit */
  color: var(--color-text);
  background: var(--color-bg-tertiary); /* Slightly different from card bg */
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid var(--color-border);
  white-space: nowrap;
  min-width:60px;
  justify-content:center;
}

/* Remove the dash prefix since we are using pills */
.skill-list li::before {
  content: none;
}

@media (max-width: 768px) {
  .skills-grid {
    grid-template-columns: 1fr; /* Stack cards vertically */
    gap: var(--space-4);
  }

  .skills {
    padding: var(--space-8) var(--space-4); /* Tighter padding for mobile edges */
  }

  .section-eyebrow {
    font-size: 1.1rem; /* Slightly smaller for mobile */
  }
}
</file>

<file path="theme.css">
/* ============================================================
   theme.css
   Global Design Tokens & Layout System
   ============================================================ */
   
:root {
  /* Backgrounds */
  --color-bg:               #FCFCFC;   
  --color-bg-secondary:     #F2F0ED;   
  --color-bg-tertiary:      #E8E5E0;   

  /* Text */
  --color-text:             #1A1917;   
  --color-text-muted:       #857F74;   
  --color-text-faint:       #B0A99F;   

  /* Accents */
  --accent:                 #003B6F;   
  --accent-mid:             #6D98BA;   
  --accent-light:           #C8DCF0;   

  /* Borders */
  --color-border:           #E0DDD8;   
  --color-border-strong:     #C5C0BA;   

  /* Typography */
  --font-display:           'Fraunces', Georgia, serif;
  --font-body:              'Outfit', system-ui, sans-serif;
  --font-mono:              'Courier New', 'Consolas', monospace;

  /* Border Radii */
  --radius-sm:              4px;
  --radius-md:              8px;
  --radius-lg:              12px;
  --radius-xl:              16px;

  /* Spacing Scale */
  --space-1:                4px;
  --space-2:                8px;
  --space-3:                12px;
  --space-4:                16px;
  --space-5:                24px;
  --space-6:                32px;
  --space-7:                48px;
  --space-8:                64px;

  /* Layout Constraints */
  --max-width:              900px;     
  --nav-height:             60px;

  /* Transitions */
  --transition-fast:        150ms ease;
  --transition-base:        250ms ease;
}

/* Dark Mode Overrides */
[data-theme="dark"] {
  --color-bg:               #0F1117;   
  --color-bg-secondary:     #1A1D24;   
  --color-bg-tertiary:      #232731;   

  --color-text:             #FCFCFC;   
  --color-text-muted:       #9AADBF;   
  --color-text-faint:       #5C6B7A;   

  --accent:                 #6D98BA;   
  --accent-mid:             #9AADBF;   
  --accent-light:           #1E3448;   

  --color-border:           #2A2F3A;   
  --color-border-strong:     #3D4556;   
}

/* ============================================================
   GLOBAL BASE STYLES & RESET
   ============================================================ */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  font-family: var(--font-body);
  background-color: var(--color-bg);
  color: var(--color-text);
  line-height: 1.7;
  transition: background-color var(--transition-base), color var(--transition-base);
  scrollbar-gutter: stable;
}

/* ============================================================
   SHARED LAYOUT CONTAINERS & REUSABLE COMPONENTS
   ============================================================ */

/* Enforces the 900px content column and ensures matching edges */
.container, .hero, .skills, .projects {
  width: 100%;
  max-width: var(--max-width);
  margin: 0 auto;
  padding-left: var(--space-5);
  padding-right: var(--space-5);
  box-sizing: border-box;
}

/* Section Header Typography Accent Styling */
.section-eyebrow {
  font-family: var(--font-display); 
  font-size: 1.5rem;
  font-weight: 300;
  font-style: italic;
  color: var(--color-text);
  margin-top: 0;
  margin-bottom: var(--space-6);
  border-bottom: 1px solid var(--color-border);
  padding-bottom: var(--space-2);
  display: inline-block;
  min-width: 150px;
}

/* ============================================================
   SPECIFIC LAYOUT OVERRIDES (CRITICAL LAYOUT CORRECTIONS)
   ============================================================ */

/* --- HERO SECTION --- */
.hero {
  padding-top: calc(var(--nav-height) + var(--space-7)); 
  padding-bottom: var(--space-6);
}

/* --- SKILLS SECTION --- */
.skills {
  padding-top: var(--space-6);
  padding-bottom: var(--space-6);
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); /* Fluid layout spacing */
  gap: var(--space-4);
  align-items: stretch;
}

/* --- PROJECTS SECTION --- */
.projects {
  padding-top: var(--space-6);
  padding-bottom: var(--space-8);
  display: flex;
  flex-direction: column;
}

.project-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
  align-items: stretch;
}

/* ============================================================
   RESPONSIVE DESIGN SYSTEM (MOBILE EDGE BREAKS)
   ============================================================ */
@media (max-width: 768px) {
  .container, .hero, .skills, .projects {
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }
  
  .hero {
    padding-top: calc(var(--nav-height) + var(--space-5));
  }

  .project-grid {
    grid-template-columns: 1fr; /* Stacks column matrix cards on mobile screens */
  }
}
</file>

