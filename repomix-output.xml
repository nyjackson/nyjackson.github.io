.form-status.success h4 {
  color: var(--color-text);
  margin-bottom: var(--space-1);
}

.form-status.success p {
  color: var(--color-text-muted);
}

.form-status.error {
  background: rgba(155, 28, 28, 0.1);
  border: 1px solid var(--color-border);
  border-left: 4px solid var(--color-danger, #9B1C1C);
  color: var(--color-text);
  align-items: center;
}

.reset-status-btn {
  background: none;
  border: none;
  color: var(--accent);
  cursor: pointer;
  font-size: 13px;
  text-decoration: underline;
  padding: 0;
  margin-top: var(--space-2);
}

/* ============================================================
   RESPONSIVE DESIGN VIEWPORTS
   ============================================================ */
@media (max-width: 768px) {
  .contact-container {
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  
  .contact {
    padding: var(--space-6) var(--space-4);
  }
}
</file>

<file path="styles/Footer.css">
